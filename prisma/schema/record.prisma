// ═══════════════════════════════════════════════════════════════════════════════
// prisma/schema/record.prisma — GeneratedRecord
//
// ARCHITECTURE NOTE:
// This model implements an EAV (Entity-Attribute-Value) pattern utilizing JSONB.
// It stores the actual rows of data generated by users for their dynamic entities.
// By using JSONB, we avoid needing to execute Postgres DDL commands every time
// a user creates or modifies an entity field.
// ═══════════════════════════════════════════════════════════════════════════════

/// A dynamic data record belonging to a GeneratedEntity.
model GeneratedRecord {
  // ── Primary Identity ─────────────────────────────────────────────
  id            String          @id @default(cuid())

  // ── Relation ──────────────────────────────────────────────────────
  entityId      String
  entity        GeneratedEntity @relation("EntityRecords", fields: [entityId], references: [id], onDelete: Cascade)

  // ── Data Payload ──────────────────────────────────────────────────
  // Stores a flat object mapping field names to their values.
  // Example: { "productName": "Laptop", "price": 999.99, "inStock": true }
  data          Json

  // ── Ownership ─────────────────────────────────────────────────────
  createdBy     String?         // ID of the User who created this record

  // ── Timestamps ────────────────────────────────────────────────────
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // ── Constraints & Indexes ─────────────────────────────────────────
  // Index on entityId for fast list queries per entity
  @@index([entityId])
  // Index on createdAt for default sorting
  @@index([entityId, createdAt])
  
  @@map("generated_records")
}
