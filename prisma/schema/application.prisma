// ═══════════════════════════════════════════════════════════════════════════════
// prisma/schema/application.prisma — GeneratedApplication & ApplicationConfig
//
// ARCHITECTURE NOTE:
// GeneratedApplication is the central domain entity in AppForge AI.
// Everything else (entities, fields, workflows, imports) belongs to an application.
//
// Soft-delete strategy:
//   - deletedAt is set on archive; record is excluded from normal queries
//   - Soft-deleted apps retain all child data (entities, fields, etc.)
//   - Hard deletion is a separate scheduled job (30-day retention)
//
// Versioning:
//   - version tracks schema evolution (incremented on entity/field changes)
//   - publishedAt tracks when the app was last made live
//
// ApplicationConfig is 1:1 with GeneratedApplication.
//   - Separated to avoid bloating the main model
//   - Contains all configuration that doesn't affect data structure
//
// @see docs/database/DATABASE_ARCHITECTURE.md
// ═══════════════════════════════════════════════════════════════════════════════

/// A metadata-defined application generated by AppForge AI.
/// This is the central tenant entity — all entities, fields, and workflows belong here.
model GeneratedApplication {
  // ── Primary Identity ─────────────────────────────────────────────
  id          String        @id @default(cuid())

  // ── Ownership (Multi-tenant scoping) ──────────────────────────────
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Application Identity ──────────────────────────────────────────
  name        String        // Display name: "My CRM App"
  slug        String        @unique // URL-safe identifier: "my-crm-app"
  description String?       @db.Text
  icon        String?       // Lucide icon name or emoji
  coverColor  String?       // Hex color for the app card

  // ── Lifecycle ─────────────────────────────────────────────────────
  status      AppStatus     @default(DRAFT)
  visibility  AppVisibility @default(PRIVATE)
  version     Int           @default(1) // Incremented on schema changes
  isPublished Boolean       @default(false)
  publishedAt DateTime?

  // ── Metadata ──────────────────────────────────────────────────────
  // Raw metadata blob for the configuration engine.
  // The engines/config/ layer parses and validates this.
  metadata    Json          @default("{}")

  // ── Timestamps & Soft Delete ──────────────────────────────────────
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?     // Soft delete: non-null = archived

  // ── Relations ─────────────────────────────────────────────────────
  config      ApplicationConfig?
  entities    GeneratedEntity[]
  workflows   GeneratedWorkflow[]
  importJobs  CSVImportJob[]

  // ── Constraints & Indexes ─────────────────────────────────────────
  @@index([userId])
  @@index([userId, status])             // Common query: get active apps for user
  @@index([userId, deletedAt])          // Soft-delete filter
  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("generated_applications")
}

/// Configuration and theme settings for a GeneratedApplication.
/// 1:1 relation with GeneratedApplication — separated to avoid model bloat.
model ApplicationConfig {
  // ── Primary Key ───────────────────────────────────────────────────
  id            String               @id @default(cuid())

  // ── Relation ──────────────────────────────────────────────────────
  applicationId String               @unique
  application   GeneratedApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // ── Theme & Branding ──────────────────────────────────────────────
  primaryColor    String?            // Hex: "#6366f1"
  secondaryColor  String?            // Hex: "#8b5cf6"
  accentColor     String?            // Hex: "#ec4899"
  fontFamily      String?            // "Inter" | "Roboto" | ...
  borderRadius    String?            // "sm" | "md" | "lg" | "full"
  darkMode        Boolean @default(false)

  // ── Layout ────────────────────────────────────────────────────────
  sidebarPosition String? @default("left") // "left" | "right"
  navStyle        String? @default("sidebar") // "sidebar" | "topbar"
  compactMode     Boolean @default(false)

  // ── Authentication Config ─────────────────────────────────────────
  allowRegistration      Boolean   @default(true)
  requireEmailVerification Boolean @default(false)
  sessionDurationHours   Int?      @default(24)
  allowedEmailDomains    String[]  @default([]) // e.g. ["company.com"]

  // ── Enabled Feature Modules ───────────────────────────────────────
  // Array of module keys: ["CSV_IMPORT", "I18N", "PWA", "NOTIFICATIONS"]
  enabledModules String[] @default([])

  // ── Locale & Internationalization ─────────────────────────────────
  defaultLocale    String @default("en")
  supportedLocales String[] @default(["en"])
  timezone         String @default("UTC")
  dateFormat       String @default("YYYY-MM-DD")
  timeFormat       String @default("HH:mm")
  currencyCode     String @default("USD")

  // ── PWA Settings ──────────────────────────────────────────────────
  pwaIcon  String?  // URL to PWA icon
  pwaColor String?  // PWA theme color
  pwaName  String?  // Short name for home screen

  // ── Custom Code (advanced) ────────────────────────────────────────
  customCSS String? @db.Text // Injected into <head>
  customJS  String? @db.Text // Injected before </body>

  // ── Permissions Config (JSON for flexibility) ──────────────────────
  // { entitySlug: { create: Role[], read: Role[], update: Role[], delete: Role[] } }
  permissionsConfig Json @default("{}")

  // ── Notification Settings ─────────────────────────────────────────
  notifyOnImport  Boolean @default(true)
  notifyOnError   Boolean @default(true)

  // ── Metadata (catch-all for future config) ────────────────────────
  metadata Json @default("{}")

  // ── Timestamps ────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("application_configs")
}
